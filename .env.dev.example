# ==========================================
# 개발 환경 설정
# ==========================================

# Build Target
BUILD_TARGET=development

# Environment
NODE_ENV=development
SPRING_PROFILES_ACTIVE=dev

# User ID for Docker (로컬 사용자와 권한 매칭)
# ⚠️ OS별 설정 방법:
# 
# [Ubuntu/Linux]
# 터미널에서 실행: echo "USER_ID=$(id -u)" && echo "GROUP_ID=$(id -g)"
# 출력된 값으로 아래 숫자를 변경하세요
#
# [Mac]
# 터미널에서 실행: id -u && id -g
# 출력된 값으로 아래 숫자를 변경하세요
#
# [Windows]
# 기본값(1000) 그대로 사용하세요
#
USER_ID=1000
GROUP_ID=1000

# Ports
DB_PORT=5432
BACKEND_PORT=8080
FRONTEND_PORT=3000

# Database (PostgreSQL)
POSTGRES_DB=mcp_calendar_dev
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/mcp_calendar_dev

# Hot Reload (개발 환경에서만 소스 마운트)
BACKEND_SRC_MOUNT=./backend/src
FRONTEND_SRC_MOUNT=./frontend
# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8080/api

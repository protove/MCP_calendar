# ==========================================
# Terraform 변수 예시 (dev-free-tier)
# ==========================================
# 이 파일을 terraform.tfvars로 복사 후 실제 값을 입력하세요.
# cp terraform.tfvars.example terraform.tfvars

# AWS 리전
aws_region    = "ap-northeast-2"
project_name  = "mcp-calendar"
environment   = "dev"

# Networking — SSH 접근 허용 IP (본인 IP만!)
# https://checkip.amazonaws.com 에서 확인
allowed_ssh_cidrs = ["YOUR_IP/32"]

# Compute
ec2_instance_type = "t3.micro"
ec2_key_pair_name = "your-key-pair-name"

# Database
db_name                = "mcp_calendar"
db_username            = "postgres"
db_password_secret_arn = "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:SECRET_NAME"

# App Secrets (Secrets Manager ARN)
jwt_secret_arn             = "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:SECRET_NAME"
gemini_api_key_secret_arn  = "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:SECRET_NAME"
weather_api_key_secret_arn = "arn:aws:secretsmanager:REGION:ACCOUNT_ID:secret:SECRET_NAME"

# Monitoring
alarm_email        = "your-email@example.com"
monthly_budget_usd = "5.0"
